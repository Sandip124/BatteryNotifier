<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BatteryNotifier.Avalonia.App"
             xmlns:local="using:BatteryNotifier.Avalonia"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <!-- Compact ToggleSwitch: strip on/off labels, clip extra right space -->
        <Style Selector="ToggleSwitch">
            <Setter Property="OnContent" Value="{x:Null}" />
            <Setter Property="OffContent" Value="{x:Null}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="MaxWidth" Value="48" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Resources/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <!-- Default fallback ensures resources resolve before theme variant is determined -->
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="AppWindowBackground" Color="#0C0C0C" />
                    <SolidColorBrush x:Key="AppCardBackground" Color="#161616" />
                    <SolidColorBrush x:Key="AppHoverBackground" Color="#1E1E1E" />
                    <SolidColorBrush x:Key="AppSecondaryButtonBg" Color="#373737" />
                    <SolidColorBrush x:Key="AppSecondaryButtonHoverBg" Color="#4B4848" />
                    <SolidColorBrush x:Key="AppForeground" Color="#F0F0F0" />
                    <SolidColorBrush x:Key="AppSubtleText" Color="#8A8A8A" />
                    <SolidColorBrush x:Key="AppCardBorder" Color="#2A2A2A" />
                    <SolidColorBrush x:Key="AppAccentForeground" Color="{DynamicResource SystemAccentColorLight1}" />
                    <SolidColorBrush x:Key="AppAccentBackground" Color="{DynamicResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="AppHeaderBackground" Color="#B0161616" />
                    <LinearGradientBrush x:Key="NotificationCardBorder" StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#45FFFFFF" Offset="0" />
                        <GradientStop Color="#18FFFFFF" Offset="0.5" />
                        <GradientStop Color="#08FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                    <Color x:Key="NotificationAcrylicTint">#0C0C0C</Color>
                    <!-- Banner colors (dark) -->
                    <SolidColorBrush x:Key="BannerCriticalBg" Color="#20EF5350" />
                    <SolidColorBrush x:Key="BannerCriticalBorder" Color="#EF5350" />
                    <SolidColorBrush x:Key="BannerCriticalText" Color="#EF9A9A" />
                    <SolidColorBrush x:Key="BannerCriticalBodyText" Color="#B0B0B0" />

                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppWindowBackground" Color="#0C0C0C" />
                    <SolidColorBrush x:Key="AppCardBackground" Color="#161616" />
                    <SolidColorBrush x:Key="AppHoverBackground" Color="#1E1E1E" />
                    <SolidColorBrush x:Key="AppSecondaryButtonBg" Color="#373737" />
                    <SolidColorBrush x:Key="AppSecondaryButtonHoverBg" Color="#4B4848" />
                    <SolidColorBrush x:Key="AppForeground" Color="#F0F0F0" />
                    <SolidColorBrush x:Key="AppSubtleText" Color="#9c9c9c" />
                    <SolidColorBrush x:Key="AppCardBorder" Color="#2A2A2A" />
                    <SolidColorBrush x:Key="AppAccentForeground" Color="{DynamicResource SystemAccentColorLight1}" />
                    <SolidColorBrush x:Key="AppAccentBackground" Color="{DynamicResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="AppHeaderBackground" Color="#B0161616" />
                    <LinearGradientBrush x:Key="NotificationCardBorder" StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#45FFFFFF" Offset="0" />
                        <GradientStop Color="#18FFFFFF" Offset="0.5" />
                        <GradientStop Color="#08FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                    <Color x:Key="NotificationAcrylicTint">#0C0C0C</Color>
                    <!-- Banner colors (dark) -->
                    <SolidColorBrush x:Key="BannerCriticalBg" Color="#20EF5350" />
                    <SolidColorBrush x:Key="BannerCriticalBorder" Color="#EF5350" />
                    <SolidColorBrush x:Key="BannerCriticalText" Color="#EF9A9A" />
                    <SolidColorBrush x:Key="BannerCriticalBodyText" Color="#B0B0B0" />

                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppWindowBackground" Color="#F5F5F5" />
                    <SolidColorBrush x:Key="AppCardBackground" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AppHoverBackground" Color="#E8E8E8" />
                    <SolidColorBrush x:Key="AppSecondaryButtonBg" Color="#E0E0E0" />
                    <SolidColorBrush x:Key="AppSecondaryButtonHoverBg" Color="#D0D0D0" />
                    <SolidColorBrush x:Key="AppForeground" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="AppSubtleText" Color="#6B6B6B" />
                    <SolidColorBrush x:Key="AppCardBorder" Color="#D0D0D0" />
                    <SolidColorBrush x:Key="AppAccentForeground" Color="{DynamicResource SystemAccentColorDark1}" />
                    <SolidColorBrush x:Key="AppAccentBackground" Color="{DynamicResource SystemAccentColor}" />
                    <SolidColorBrush x:Key="AppHeaderBackground" Color="#B0F0F0F0" />
                    <LinearGradientBrush x:Key="NotificationCardBorder" StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#30000000" Offset="0" />
                        <GradientStop Color="#15000000" Offset="0.5" />
                        <GradientStop Color="#25000000" Offset="1" />
                    </LinearGradientBrush>
                    <Color x:Key="NotificationAcrylicTint">#F5F5F5</Color>
                    <!-- Banner colors (light) -->
                    <SolidColorBrush x:Key="BannerCriticalBg" Color="#18D32F2F" />
                    <SolidColorBrush x:Key="BannerCriticalBorder" Color="#D32F2F" />
                    <SolidColorBrush x:Key="BannerCriticalText" Color="#C62828" />
                    <SolidColorBrush x:Key="BannerCriticalBodyText" Color="#424242" />

                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Override ToggleSwitch min width to remove right padding -->
            <x:Double x:Key="ToggleSwitchThemeMinWidth">40</x:Double>

            <!-- Semantic status colors (same in both themes) -->
            <Color x:Key="StatusGreen">#388E3C</Color>
            <Color x:Key="StatusAmber">#F57A00</Color>
            <Color x:Key="StatusRed">#D32F2F</Color>
            <Color x:Key="StatusCriticalRed">#FF1744</Color>
            <Color x:Key="StatusBlue">#0288D1</Color>
            <Color x:Key="StatusMuted">#8A8A8A</Color>

            <!-- Accent colors for specific UI elements -->
            <Color x:Key="AccentBrightGreen">#00E676</Color>
            <Color x:Key="AccentBrightAmber">#FFAB00</Color>
            <Color x:Key="AccentBrightRed">#FF1744</Color>
            <Color x:Key="AccentFire">#F4511E</Color>
            <Color x:Key="AccentPower">#FB8C00</Color>
            <Color x:Key="AccentLightbulb">#FBC02D</Color>

            <!-- Banner backgrounds (tinted, semi-transparent) -->
            <Color x:Key="BannerDndBackground">#2E1976D2</Color>
            <Color x:Key="BannerPausedBackground">#2EFF9800</Color>
            <Color x:Key="BannerCriticalBackground">#30FF1744</Color>

            <SolidColorBrush x:Key="BannerDndBrush" Color="{StaticResource BannerDndBackground}" />
            <SolidColorBrush x:Key="BannerPausedBrush" Color="{StaticResource BannerPausedBackground}" />
            <SolidColorBrush x:Key="BannerCriticalBrush" Color="{StaticResource BannerCriticalBackground}" />
            <SolidColorBrush x:Key="StatusGreenBrush" Color="{StaticResource StatusGreen}" />
            <SolidColorBrush x:Key="StatusAmberBrush" Color="{StaticResource StatusAmber}" />
            <SolidColorBrush x:Key="StatusRedBrush" Color="{StaticResource StatusRed}" />
            <SolidColorBrush x:Key="StatusCriticalRedBrush" Color="{StaticResource AccentBrightRed}" />
            <SolidColorBrush x:Key="AccentFireBrush" Color="{StaticResource AccentFire}" />
            <SolidColorBrush x:Key="AccentPowerBrush" Color="{StaticResource AccentPower}" />
            <SolidColorBrush x:Key="AccentLightbulbBrush" Color="{StaticResource AccentLightbulb}" />
        </ResourceDictionary>

        <ControlTheme x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppForeground}" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />

            <Setter Property="Template">
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            Cursor="{TemplateBinding Cursor}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <ContentPresenter
                            Foreground="{TemplateBinding Foreground}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource AppHoverBackground}" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource AppSecondaryButtonBg}" />

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource AppSecondaryButtonHoverBg}" />
            </Style>
        </ControlTheme>

    </Application.Resources>

</Application>