<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BatteryNotifier.Avalonia.ViewModels"
             xmlns:components="clr-namespace:BatteryNotifier.Avalonia.Views.Components"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
             x:Class="BatteryNotifier.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <Style Selector="Button.theme-active">
            <Setter Property="Background" Value="#3878C5" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Material-style slider: thin track, round thumb, accent fill -->
        <Style Selector="Slider.material">
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Slider.material /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Height" Value="3" />
            <Setter Property="CornerRadius" Value="1.5" />
        </Style>
        <Style Selector="Slider.material /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Height" Value="3" />
            <Setter Property="CornerRadius" Value="1.5" />
        </Style>
        <Style Selector="Slider.material /template/ Thumb">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
        </Style>
        <Style Selector="Slider.material /template/ Thumb /template/ Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource AppAccentForeground}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Header (drag handle) -->
        <Border Grid.Row="0" Padding="12,10" Name="SettingsTitleBar"
                Background="{DynamicResource AppHeaderBackground}"
                PointerPressed="SettingsTitleBar_PointerPressed">
            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                <Button Command="{Binding BackCommand}" Grid.Column="0"
                        Theme="{StaticResource PrimaryButton}"
                        Foreground="{DynamicResource AppAccentForeground}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource Icon.CaretLeft}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Width="10" Height="10" />
                        <TextBlock Margin="4,0,0,0" FontSize="12">Back</TextBlock>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                           Margin="8,0,0,0" Foreground="{DynamicResource AppForeground}">Settings</TextBlock>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="10,10,10,0">
            <StackPanel Spacing="10" Margin="0,0,0,30">

                <!-- Appearance & Behaviour -->
                <Border CornerRadius="12" BorderThickness="1" ClipToBounds="True"
                        BorderBrush="{DynamicResource AppCardBorder}"
                        Background="{DynamicResource AppCardBackground}">
                    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
                        <Border Grid.Row="0" Padding="12,10,12,4">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource Icon.Sliders}"
                                    VerticalAlignment="Center" Width="12" Height="12"
                                    Foreground="{DynamicResource AppSubtleText}" />
                                <TextBlock Margin="6,0,0,0" FontSize="12" FontWeight="Normal"
                                           Foreground="{DynamicResource AppSubtleText}">APPEARANCE &amp; BEHAVIOUR</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Padding="12,8">
                            <StackPanel Spacing="8">

                                <!-- Theme -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13">Theme</TextBlock>
                                    <Border Grid.Column="1" CornerRadius="4" BorderBrush="#9C9C9C"
                                            BorderThickness="1" ClipToBounds="True">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Classes.theme-active="{Binding IsLightTheme}"
                                                    Command="{Binding SetLightThemeCommand}"
                                                    Theme="{StaticResource PrimaryButton}"
                                                    CornerRadius="4,0,0,4">Light</Button>
                                            <Button Classes.theme-active="{Binding IsSystemTheme}"
                                                    Command="{Binding SetSystemThemeCommand}"
                                                    Theme="{StaticResource PrimaryButton}"
                                                    CornerRadius="0">System</Button>
                                            <Button Classes.theme-active="{Binding IsDarkTheme}"
                                                    Command="{Binding SetDarkThemeCommand}"
                                                    Theme="{StaticResource PrimaryButton}"
                                                    CornerRadius="0,4,4,0">Dark</Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Launch at Startup -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13">Launch at system startup</TextBlock>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding LaunchAtStartup}"
                                                  OnContent="" OffContent=""
                                                  Margin="0" Padding="0" />
                                </Grid>

                                <!-- Start Minimized -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13">Start minimized to tray</TextBlock>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding StartMinimized}"
                                                  OnContent="" OffContent=""
                                                  Margin="0" Padding="0" />
                                </Grid>

                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Notifications & Sounds -->
                <Border CornerRadius="12" BorderThickness="1" ClipToBounds="True"
                        BorderBrush="{DynamicResource AppCardBorder}"
                        Background="{DynamicResource AppCardBackground}">
                    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
                        <Border Grid.Row="0" Padding="12,10,12,4">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource Icon.BellSimple}"
                                    VerticalAlignment="Center" Width="12" Height="12"
                                    Foreground="{DynamicResource AppSubtleText}" />
                                <TextBlock Margin="6,0,0,0" FontSize="12" FontWeight="Normal"
                                           Foreground="{DynamicResource AppSubtleText}">NOTIFICATIONS &amp; SOUNDS</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Padding="12,0,12,10">
                            <StackPanel Spacing="12">
                                <components:BatteryNotificationSection DataContext="{Binding FullBatterySection}" />
                                <components:BatteryNotificationSection DataContext="{Binding LowBatterySection}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
