<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BatteryNotifier.Avalonia.ViewModels"
             xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="600"
             x:Class="BatteryNotifier.Avalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>
        <Style Selector="Button.theme-active">
            <Setter Property="Background" Value="#3878C5" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Material-style slider: thin track, round thumb, accent fill -->
        <Style Selector="Slider.material">
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Slider.material /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Height" Value="3" />
            <Setter Property="CornerRadius" Value="1.5" />
        </Style>
        <Style Selector="Slider.material /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Height" Value="3" />
            <Setter Property="CornerRadius" Value="1.5" />
        </Style>
        <Style Selector="Slider.material /template/ Thumb">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
        </Style>
        <Style Selector="Slider.material /template/ Thumb /template/ Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource AppAccentForeground}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Header (drag handle) -->
        <Border Grid.Row="0" Padding="12,10" Name="SettingsTitleBar"
                Background="{DynamicResource AppHeaderBackground}"
                PointerPressed="SettingsTitleBar_PointerPressed">
            <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                <Button Command="{Binding BackCommand}" Grid.Column="0"
                        Theme="{StaticResource PrimaryButton}"
                        Foreground="{DynamicResource AppAccentForeground}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <iconPacks:PackIconPhosphorIcons Kind="CaretLeft"
                                                         VerticalAlignment="Center"
                                                         HorizontalAlignment="Center"
                                                         Width="10" Height="10" />
                        <TextBlock Margin="4,0,0,0" FontSize="12">Back</TextBlock>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                           Margin="8,0,0,0" Foreground="{DynamicResource AppForeground}">Settings</TextBlock>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="10,10,10,0">
            <StackPanel Spacing="10" Margin="0,0,0,30">

                <!-- Appearance & Behaviour -->
                <Border CornerRadius="12" BorderThickness="1" ClipToBounds="True"
                        BorderBrush="{DynamicResource AppCardBorder}"
                        Background="{DynamicResource AppCardBackground}">
                    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
                        <Border Grid.Row="0" Padding="12,10,12,4">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconPhosphorIcons Kind="Sliders"
                                    VerticalAlignment="Center" Width="12" Height="12"
                                    Foreground="{DynamicResource AppSubtleText}" />
                                <TextBlock Margin="6,0,0,0" FontSize="12" FontWeight="Normal"
                                           Foreground="{DynamicResource AppSubtleText}">APPEARANCE &amp; BEHAVIOUR</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Padding="12,8">
                            <StackPanel Spacing="8">

                                <!-- Theme -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13">Theme</TextBlock>
                                    <Border Grid.Column="1" CornerRadius="4" BorderBrush="#9C9C9C"
                                            BorderThickness="1" ClipToBounds="True">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Classes.theme-active="{Binding IsLightTheme}"
                                                    Command="{Binding SetLightThemeCommand}"
                                                    Theme="{StaticResource PrimaryButton}"
                                                    CornerRadius="4,0,0,4">Light</Button>
                                            <Button Classes.theme-active="{Binding IsSystemTheme}"
                                                    Command="{Binding SetSystemThemeCommand}"
                                                    Theme="{StaticResource PrimaryButton}"
                                                    CornerRadius="0">System</Button>
                                            <Button Classes.theme-active="{Binding IsDarkTheme}"
                                                    Command="{Binding SetDarkThemeCommand}"
                                                    Theme="{StaticResource PrimaryButton}"
                                                    CornerRadius="0,4,4,0">Dark</Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Launch at Startup -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13">Launch at system startup</TextBlock>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding LaunchAtStartup}"
                                                  OnContent="" OffContent=""
                                                  Margin="0" Padding="0" />
                                </Grid>

                                <!-- Start Minimized -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13">Start minimized to tray</TextBlock>
                                    <ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding StartMinimized}"
                                                  OnContent="" OffContent=""
                                                  Margin="0" Padding="0" />
                                </Grid>

                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Notifications & Sounds -->
                <Border CornerRadius="12" BorderThickness="1" ClipToBounds="True"
                        BorderBrush="{DynamicResource AppCardBorder}"
                        Background="{DynamicResource AppCardBackground}">
                    <Grid RowDefinitions="Auto,*" ColumnDefinitions="*">
                        <Border Grid.Row="0" Padding="12,10,12,4">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <iconPacks:PackIconPhosphorIcons Kind="BellSimple"
                                    VerticalAlignment="Center" Width="12" Height="12"
                                    Foreground="{DynamicResource AppSubtleText}" />
                                <TextBlock Margin="6,0,0,0" FontSize="12" FontWeight="Normal"
                                           Foreground="{DynamicResource AppSubtleText}">NOTIFICATIONS &amp; SOUNDS</TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Padding="12,0,12,10">
                            <StackPanel Spacing="0">

                                <!-- Full Battery -->
                                <Grid ColumnDefinitions="28,*,Auto" VerticalAlignment="Center">
                                    <Image Grid.Column="0" Margin="0,0,6,0"
                                           Source="/Assets/FullBattery.png" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="SemiBold">Full Battery</TextBlock>
                                    <ToggleSwitch Grid.Column="2"
                                                  IsChecked="{Binding FullBatteryNotification}"
                                                  OnContent="" OffContent=""
                                                  Margin="0" Padding="0" />
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="11" Foreground="{DynamicResource AppSubtleText}">Threshold</TextBlock>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold"
                                               Text="{Binding FullBatteryNotificationValue, StringFormat='{}{0}%'}" />
                                </Grid>
                                <Slider Minimum="50" Maximum="100"
                                        Value="{Binding FullBatteryNotificationValue}"
                                        Classes="material" />

                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,0,0">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding FullBatterySoundPath}"
                                             IsReadOnly="True"
                                             Watermark="Default sound"
                                             FontSize="11" Padding="6,6" />
                                    <Button Grid.Column="1" Margin="4,0,0,0"
                                            Command="{Binding BrowseFullBatterySoundCommand}"
                                            Theme="{StaticResource SecondaryButton}"
                                            FontSize="11" Padding="8,6">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <iconPacks:PackIconPhosphorIcons Kind="FolderOpen"
                                                Width="12" Height="12" VerticalAlignment="Center" />
                                            <TextBlock VerticalAlignment="Center">Browse</TextBlock>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Margin="4,0,0,0"
                                            Command="{Binding ResetFullBatterySoundCommand}"
                                            Theme="{StaticResource SecondaryButton}"
                                            FontSize="11" Padding="8,6"
                                            IsVisible="{Binding FullBatterySoundPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <iconPacks:PackIconPhosphorIcons Kind="X"
                                            Width="12" Height="12" />
                                    </Button>
                                </Grid>

                                <!-- Spacer between sections -->
                                <Border Height="16" />

                                <!-- Low Battery -->
                                <Grid ColumnDefinitions="28,*,Auto" VerticalAlignment="Center">
                                    <Image Grid.Column="0" Margin="0,0,6,0"
                                           Source="/Assets/LowBattery.png" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               FontSize="13" FontWeight="SemiBold">Low Battery</TextBlock>
                                    <ToggleSwitch Grid.Column="2"
                                                  IsChecked="{Binding LowBatteryNotification}"
                                                  OnContent="" OffContent=""
                                                  Margin="0" Padding="0" />
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="11" Foreground="{DynamicResource AppSubtleText}">Threshold</TextBlock>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold"
                                               Text="{Binding LowBatteryNotificationValue, StringFormat='{}{0}%'}" />
                                </Grid>
                                <Slider Minimum="5" Maximum="50"
                                        Value="{Binding LowBatteryNotificationValue}"
                                        Classes="material" />

                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,0,0">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding LowBatterySoundPath}"
                                             IsReadOnly="True"
                                             Watermark="Default sound"
                                             FontSize="11" Padding="6,6" />
                                    <Button Grid.Column="1" Margin="4,0,0,0"
                                            Command="{Binding BrowseLowBatterySoundCommand}"
                                            Theme="{StaticResource SecondaryButton}"
                                            FontSize="11" Padding="8,6">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <iconPacks:PackIconPhosphorIcons Kind="FolderOpen"
                                                Width="12" Height="12" VerticalAlignment="Center" />
                                            <TextBlock VerticalAlignment="Center">Browse</TextBlock>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Margin="4,0,0,0"
                                            Command="{Binding ResetLowBatterySoundCommand}"
                                            Theme="{StaticResource SecondaryButton}"
                                            FontSize="11" Padding="8,6"
                                            IsVisible="{Binding LowBatterySoundPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <iconPacks:PackIconPhosphorIcons Kind="X"
                                            Width="12" Height="12" />
                                    </Button>
                                </Grid>

                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
