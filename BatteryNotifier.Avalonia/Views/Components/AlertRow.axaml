<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BatteryNotifier.Avalonia.ViewModels"
             xmlns:controls="clr-namespace:BatteryNotifier.Avalonia.Controls"
             mc:Ignorable="d"
             x:Class="BatteryNotifier.Avalonia.Views.Components.AlertRow"
             x:DataType="vm:AlertRowViewModel">

    <StackPanel Spacing="10">

        <!-- ── Header: label + actions ── -->
        <!-- Delete button — top right, separate from actions -->
        <Button Command="{Binding DeleteCommand}"
                Theme="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right"
                Padding="4" Margin="0,-2,-2,0"
                ToolTip.Tip="Remove alert"
                IsVisible="{Binding CanDelete}">
            <PathIcon Data="{StaticResource Icon.X}" Width="9" Height="9"
                      Foreground="{DynamicResource AppSubtleText}" Opacity="0.6" />
        </Button>

        <!-- Header: label + toggle + preview -->
        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center" Margin="0,2,0,0">
            <TextBlock Grid.Column="0" Text="{Binding Label}"
                       FontSize="14" FontWeight="SemiBold"
                       Padding="0,2"
                       IsVisible="{Binding IsDefault}" />
            <TextBox Grid.Column="0" Text="{Binding Label}"
                     FontSize="14" FontWeight="SemiBold"
                     BorderThickness="0" Background="Transparent"
                     Padding="0,2"
                     IsVisible="{Binding CanDelete}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <Button Command="{Binding PreviewCommand}"
                        Theme="{StaticResource SecondaryButton}"
                        Padding="7,5" CornerRadius="6"
                        ToolTip.Tip="Preview alert">
                    <PathIcon Data="{StaticResource Icon.Play}" Width="13" Height="13"
                              Foreground="{DynamicResource AppSubtleText}" />
                </Button>
                <ToggleSwitch IsChecked="{Binding IsEnabled}"
                              OnContent="" OffContent=""
                              Margin="0" Padding="0"
                              VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ── Range section ── -->
        <StackPanel Spacing="4">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="12" Foreground="{DynamicResource AppSubtleText}">Battery Range</TextBlock>
                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppForeground}">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}% – {1}%">
                            <Binding Path="LowerBound" />
                            <Binding Path="UpperBound" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
            <controls:RangeSlider Minimum="0" Maximum="100"
                                  LowerValue="{Binding LowerBound}"
                                  UpperValue="{Binding UpperBound}"
                                  MinimumGap="5"
                                  HorizontalAlignment="Stretch" />
        </StackPanel>

        <!-- ── Sound + Flash color row ── -->
        <Grid ColumnDefinitions="*,12,*" Margin="0,2,0,0">
            <!-- Sound picker -->
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock FontSize="12" Foreground="{DynamicResource AppSubtleText}">Sound</TextBlock>
                <Button Command="{Binding OpenSoundPickerCommand}"
                        Theme="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Padding="8,6" MinHeight="32"
                        CornerRadius="6">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <PathIcon Grid.Column="0"
                                  Data="{StaticResource Icon.SpeakerHigh}"
                                  Width="12" Height="12"
                                  Foreground="{DynamicResource AppSubtleText}"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SoundDisplayName}"
                                   FontSize="11.5"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <PathIcon Grid.Column="2"
                                  Data="{StaticResource Icon.CaretLeft}"
                                  Width="8" Height="8"
                                  Foreground="{DynamicResource AppSubtleText}"
                                  VerticalAlignment="Center"
                                  RenderTransform="rotate(270deg)" />
                    </Grid>
                </Button>
            </StackPanel>

            <!-- Flash color picker -->
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock FontSize="12" Foreground="{DynamicResource AppSubtleText}">Flash Color</TextBlock>
                <ComboBox ItemsSource="{x:Static vm:AlertRowViewModel.FlashColorOptions}"
                          SelectedItem="{Binding SelectedFlashColorOption}"
                          HorizontalAlignment="Stretch"
                          Padding="8,6" MinHeight="32"
                          CornerRadius="6"
                          FontSize="11.5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:FlashColorOption">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="14" Height="14"
                                        CornerRadius="7"
                                        Background="{Binding PreviewBrush}"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource AppCardBorder}"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           FontSize="11.5" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Grid>

    </StackPanel>

</UserControl>
