<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:BatteryNotifier.Avalonia.Controls"
        x:Class="BatteryNotifier.Avalonia.Views.ScreenFlashOverlay"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        Focusable="False"
        ShowActivated="False">

    <controls:EdgeGlowRenderer x:Name="GlowControl"
                                GlowThickness="60"
                                Opacity="0" />
</Window>
