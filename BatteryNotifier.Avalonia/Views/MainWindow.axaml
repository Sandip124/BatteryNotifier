<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BatteryNotifier.Avalonia.ViewModels"
        xmlns:controls="using:BatteryNotifier.Avalonia.Controls"
        xmlns:components="clr-namespace:BatteryNotifier.Avalonia.Views.Components"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="510"
        x:Class="BatteryNotifier.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="400" Height="510"
        CanResize="False"
        SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Icon="/Assets/battery-notifier-logo.ico"
        Title="BatteryNotifier">

    <Border ClipToBounds="True" CornerRadius="10"
            Background="{DynamicResource AppWindowBackground}">
      <Panel>
      <Border Padding="4">
        <Grid>

        <!-- Home screen (always visible — settings overlays on top) -->
        <Grid RowDefinitions="Auto,*">

            <!-- Header (drag handle) — ZIndex keeps it above the ambient glow -->
            <Border Grid.Row="0" Padding="12,10" Name="TitleBar"  CornerRadius="8"
                    ZIndex="1"
                    Background="{DynamicResource AppHeaderBackground}"
                    PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="32,*,Auto" VerticalAlignment="Center">
                    <Image Grid.Column="0" Margin="0,0,10,0" Width="28" Height="28"
                           Source="/Assets/BatteryNotifierLogo.png"
                           RenderOptions.BitmapInterpolationMode="MediumQuality" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppForeground}">BatteryNotifier</TextBlock>
                        <TextBlock FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppSubtleText}"
                                   Text="{Binding Version, StringFormat='v{0}'}" />
                    </StackPanel>
                    <Button Command="{Binding NavigateToSettingsCommand}" Grid.Column="2"
                            Theme="{StaticResource PrimaryButton}">
                        <PathIcon Data="{StaticResource Icon.GearSix}" Width="16" Height="16" />
                    </Button>
                </Grid>
            </Border>

            <!-- Battery Status -->
            <Grid Grid.Row="1" ColumnDefinitions="*" ClipToBounds="False">
                <Border Margin="8,4,8,8" ClipToBounds="False">
                    <Grid RowDefinitions="*,Auto,Auto" ColumnDefinitions="*" ClipToBounds="False">

                        <!-- Battery display area — tappable to open health details -->
                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Spacing="0" ClipToBounds="False">
                            <controls:BatteryIndicatorControl
                                Width="200" Height="110"
                                Percentage="{Binding BatteryPercentage}"
                                IsCharging="{Binding IsCharging}" />
                            <TextBlock TextAlignment="Center" FontSize="40" FontWeight="Bold"
                                       Margin="0,12,0,0"
                                       Text="{Binding BatteryPercentage, StringFormat='{}{0:F0}%'}" />

                            <!-- Charging status — green, prominent -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        Margin="0,2,0,0"
                                        IsVisible="{Binding IsCharging}">
                                <PathIcon Data="{StaticResource Icon.LightningFill}"
                                          VerticalAlignment="Center"
                                          Foreground="#4CAF50"
                                          Width="13" Height="13" />
                                <TextBlock Margin="3,0,0,0" VerticalAlignment="Center"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#4CAF50" Text="{Binding BatteryStatus}" />
                            </StackPanel>

                            <!-- Discharging status — uses foreground, not subtle -->
                            <TextBlock TextAlignment="Center" FontSize="14"
                                       Margin="0,2,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppForeground}"
                                       IsVisible="{Binding IsCharging, Converter={x:Static BoolConverters.Not}}"
                                       Text="{Binding BatteryStatus}" />

                            <!-- Contextual detail: time + tip — lighter, clearly secondary -->
                            <TextBlock TextAlignment="Center"
                                       Margin="0,4,0,0"
                                       FontSize="11.5"
                                       Opacity="0.5"
                                       Foreground="{DynamicResource AppForeground}"
                                       IsVisible="{Binding StatusLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Text="{Binding StatusLine}" />

                            <!-- Health pill (clickable) -->
                            <Border HorizontalAlignment="Center"
                                    Margin="0,10,0,0"
                                    Padding="10,5"
                                    CornerRadius="12"
                                    Background="{DynamicResource AppCardBackground}"
                                    BorderBrush="{DynamicResource AppCardBorder}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    PointerPressed="HealthBar_PointerPressed">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <PathIcon Data="{Binding HealthIcon}"
                                              Foreground="{Binding HealthAccentColor}"
                                              Width="10" Height="10" VerticalAlignment="Center" />
                                    <TextBlock FontSize="11" FontWeight="Medium"
                                               Foreground="{Binding HealthAccentColor}"
                                               VerticalAlignment="Center"
                                               Text="{Binding HealthSummary}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- DND notice -->
                        <Border Grid.Row="1"
                                IsVisible="{Binding IsDndActive}"
                                CornerRadius="8" Padding="10,7"
                                Margin="0,0,0,6"
                                Background="{StaticResource BannerDndBrush}">
                            <Grid ColumnDefinitions="Auto,8,*">
                                <PathIcon Grid.Column="0"
                                          Data="{StaticResource Icon.BellSlash}"
                                          Width="14" Height="14"
                                          Foreground="{DynamicResource AppAccentForeground}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DndMessage}"
                                           FontSize="11.5"
                                           Foreground="{DynamicResource AppAccentForeground}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Notifications paused notice (hidden when DND is active — DND already suppresses) -->
                        <Border Grid.Row="1"
                                IsVisible="{Binding ShowPausedBanner}"
                                CornerRadius="8" Padding="10,7"
                                Margin="0,0,0,6"
                                Background="{StaticResource BannerPausedBrush}">
                            <Grid ColumnDefinitions="Auto,8,*,8,Auto">
                                <PathIcon Grid.Column="0"
                                          Data="{StaticResource Icon.BellSlash}"
                                          Width="14" Height="14"
                                          Foreground="{StaticResource StatusAmberBrush}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="Notifications paused · auto-resumes in 2h"
                                           FontSize="11.5"
                                           Foreground="{StaticResource StatusAmberBrush}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="4"
                                        Command="{Binding ResumeNotificationsCommand}"
                                        Theme="{StaticResource PrimaryButton}"
                                        Padding="8,3" FontSize="10"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Resume notifications">
                                    <TextBlock Text="Resume" Foreground="{StaticResource StatusAmberBrush}" FontWeight="SemiBold" />
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Quick Settings -->
                        <Border Grid.Row="2" CornerRadius="12" BorderThickness="1" ClipToBounds="True"
                                Margin="0,6,0,0"
                                BorderBrush="{DynamicResource AppCardBorder}"
                                Background="{DynamicResource AppCardBackground}">
                            <StackPanel>
                                <TextBlock Padding="12,10,12,4" FontSize="12" FontWeight="Normal"
                                           Foreground="{DynamicResource AppSubtleText}">QUICK SETTINGS</TextBlock>

                                <!-- Full Battery notification -->
                                <Border Padding="12,4">
                                    <Grid ColumnDefinitions="Auto,*,42">
                                        <PathIcon Grid.Column="0"
                                                  Data="{StaticResource Icon.BatteryFullFill}"
                                                  Foreground="#388E3C"
                                                  Width="20" Height="20"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13">Full Battery Notification</TextBlock>
                                        <ToggleSwitch Grid.Column="2"
                                                      IsChecked="{Binding FullBatteryAlertEnabled}"
                                                      OnContent="" OffContent=""
                                                      Margin="0" Padding="0" />
                                    </Grid>
                                </Border>

                                <!-- Low Battery notification -->
                                <Border Padding="12,4,12,8">
                                    <Grid ColumnDefinitions="Auto,*,42">
                                        <PathIcon Grid.Column="0"
                                                  Data="{StaticResource Icon.BatteryLowFill}"
                                                  Foreground="#F57A00"
                                                  Width="20" Height="20"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13">Low Battery Notification</TextBlock>
                                        <ToggleSwitch Grid.Column="2"
                                                      IsChecked="{Binding LowBatteryAlertEnabled}"
                                                      OnContent="" OffContent=""
                                                      Margin="0" Padding="0" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>


        </Grid>

        <!-- Settings screen (overlays home when CurrentView is set) -->
        <ContentControl x:Name="SettingsContent"
                        Content="{Binding CurrentView}"
                        Background="{DynamicResource AppWindowBackground}"
                        IsVisible="False"
                        RenderTransform="translateX(400px)">
            <!-- Transitions set dynamically in code-behind for directional easing -->
        </ContentControl>

        <!-- Inline notification toast -->
        <Border IsVisible="{Binding IsInlineNotificationVisible}"
                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                Margin="8,56,8,0"
                CornerRadius="8" Padding="10,8"
                ZIndex="10"
                BoxShadow="0 2 8 0 #40000000"
                Name="InlineNotificationBar"
                Classes.Success="{Binding IsInlineSuccess}"
                Classes.Warning="{Binding IsInlineWarning}"
                Classes.Error="{Binding IsInlineError}">
            <Border.Styles>
                <Style Selector="Border#InlineNotificationBar">
                    <Setter Property="Background" Value="#1976D2" />
                </Style>
                <Style Selector="Border#InlineNotificationBar.Success">
                    <Setter Property="Background" Value="#388E3C" />
                </Style>
                <Style Selector="Border#InlineNotificationBar.Warning">
                    <Setter Property="Background" Value="#F57A00" />
                </Style>
                <Style Selector="Border#InlineNotificationBar.Error">
                    <Setter Property="Background" Value="#D32F2F" />
                </Style>
            </Border.Styles>
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding InlineNotificationMessage}"
                           Foreground="White" FontSize="12.5"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1" Command="{Binding DismissInlineNotificationCommand}"
                        Background="Transparent" BorderThickness="0"
                        Padding="4" Margin="4,0,0,0"
                        VerticalAlignment="Center" Cursor="Hand">
                    <PathIcon Data="{StaticResource Icon.X}" Width="10" Height="10"
                              Foreground="#CCFFFFFF" />
                </Button>
            </Grid>
        </Border>

        </Grid>
      </Border>

      <!-- Health bottom sheet — outside padding, fills full clip area -->
      <components:HealthBottomSheet
          x:Name="HealthSheet"
          IsVisible="False"
          ZIndex="5" />
      </Panel>
    </Border>
</Window>
