<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BatteryNotifier.Avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="BatteryNotifier.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="400" Height="500"
        CanResize="False"
        SystemDecorations="BorderOnly"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Icon="/Assets/battery-notifier-logo.ico"
        Title="BatteryNotifier">

    <Border ClipToBounds="True"
            Background="{DynamicResource AppWindowBackground}">
      <Border Padding="4">
        <Grid>

        <!-- Home screen (visible when not in settings) -->
        <Grid RowDefinitions="Auto,*,Auto"
              IsVisible="{Binding CurrentView, Converter={x:Static ObjectConverters.IsNull}}">

            <!-- Header (drag handle) -->
            <Border Grid.Row="0" Padding="12,10" Name="TitleBar"
                    Background="{DynamicResource AppHeaderBackground}"
                    PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="32,*,Auto,4,Auto" VerticalAlignment="Center">
                    <Image Grid.Column="0" Margin="0,0,10,0" Width="28" Height="28"
                           Source="/Assets/BatteryNotifierLogo.png"
                           RenderOptions.BitmapInterpolationMode="MediumQuality" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppForeground}">BatteryNotifier</TextBlock>
                    <Button Grid.Column="2"
                            Theme="{StaticResource PrimaryButton}">
                        <PathIcon Data="{StaticResource Icon.Info}" Width="16" Height="16" />
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="Hide Window" Command="{Binding HideWindowCommand}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource Icon.EyeSlash}" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="Check for Updates..." Command="{Binding CheckForUpdatesCommand}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource Icon.ArrowsClockwise}" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Send Logs..." Command="{Binding SendLogsCommand}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource Icon.Bug}" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="GitHub" Command="{Binding OpenGitHubCommand}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource Icon.GithubLogo}" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="Exit" Command="{Binding ExitCommand}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource Icon.SignOut}" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Command="{Binding NavigateToSettingsCommand}" Grid.Column="4"
                            Theme="{StaticResource PrimaryButton}">
                        <PathIcon Data="{StaticResource Icon.GearSix}" Width="16" Height="16" />
                    </Button>
                </Grid>
            </Border>

            <!-- Battery Status -->
            <Grid Grid.Row="1" ColumnDefinitions="*">
                <Border Margin="5">
                    <Grid RowDefinitions="*,Auto" ColumnDefinitions="*">

                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Height="140" Source="{Binding BatteryImage}"
                                   RenderOptions.BitmapInterpolationMode="MediumQuality" />
                            <TextBlock TextAlignment="Center" FontSize="42" FontWeight="Bold" Padding="0,2"
                                       Text="{Binding BatteryPercentage, StringFormat='{}{0:F0}%'}" />

                            <!-- Charging indicator -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        IsVisible="{Binding IsCharging}">
                                <PathIcon Data="{StaticResource Icon.LightningFill}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Foreground="#15C245"
                                          Width="14" Height="14" />
                                <TextBlock Margin="4,0,0,0" VerticalAlignment="Center"
                                           Foreground="#15C245" Text="{Binding BatteryStatus}" />
                            </StackPanel>

                            <!-- Discharging status -->
                            <TextBlock TextAlignment="Center"
                                       Foreground="{DynamicResource AppSubtleText}"
                                       IsVisible="{Binding IsCharging, Converter={x:Static BoolConverters.Not}}"
                                       Text="{Binding BatteryStatus}" />

                            <TextBlock TextAlignment="Center" Padding="0,2"
                                       FontSize="13"
                                       Foreground="{DynamicResource AppSubtleText}"
                                       Text="{Binding TimeRemaining}" />
                        </StackPanel>

                        <!-- Quick Settings -->
                        <Border Grid.Row="1" CornerRadius="12" BorderThickness="1" ClipToBounds="True"
                                BorderBrush="{DynamicResource AppCardBorder}"
                                Background="{DynamicResource AppCardBackground}">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*">
                                <TextBlock Grid.Row="0" Padding="12,10,12,4" FontSize="12" FontWeight="Normal"
                                           Foreground="{DynamicResource AppSubtleText}">QUICK SETTINGS</TextBlock>
                                <Grid Margin="12,6,12,10" Grid.Row="1" RowDefinitions="Auto,6,Auto" ColumnDefinitions="*">

                                    <Grid Grid.Row="0" ColumnDefinitions="42,*,Auto" VerticalAlignment="Center">
                                        <Image Grid.Column="0" Margin="0,0,8,0"
                                               Source="/Assets/FullBattery.png"
                                               RenderOptions.BitmapInterpolationMode="MediumQuality" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13">Full Battery Notification</TextBlock>
                                        <ToggleSwitch Grid.Column="2"
                                                      IsChecked="{Binding FullBatteryNotification}"
                                                      OnContent="" OffContent=""
                                                      Margin="0" Padding="0" />
                                    </Grid>

                                    <Grid Grid.Row="2" ColumnDefinitions="42,*,Auto" VerticalAlignment="Center">
                                        <Image Grid.Column="0" Margin="0,0,8,0"
                                               Source="/Assets/LowBattery.png"
                                               RenderOptions.BitmapInterpolationMode="MediumQuality" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="13">Low Battery Notification</TextBlock>
                                        <ToggleSwitch Grid.Column="2"
                                                      IsChecked="{Binding LowBatteryNotification}"
                                                      OnContent="" OffContent=""
                                                      Margin="0" Padding="0" />
                                    </Grid>

                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="12,6">
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11"
                               FontStyle="Italic"
                               Foreground="{DynamicResource AppSubtleText}"
                               Text="{Binding StatusMessage}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource AppSubtleText}"
                               Text="{Binding Version, StringFormat='v{0}'}" />
                </Grid>
            </Border>

        </Grid>

        <!-- Settings screen (overlays home when CurrentView is set) -->
        <ContentControl Content="{Binding CurrentView}"
                        IsVisible="{Binding CurrentView, Converter={x:Static ObjectConverters.IsNotNull}}" />

        </Grid>
      </Border>
    </Border>
</Window>
